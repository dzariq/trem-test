## ── Production environment ───────────────────────
## Loaded automatically by:  npm run build:production
## Replace these values when you create a separate Production Supabase project.
VITE_APP_ENV=production
VITE_SUPABASE_PROJECT_ID="REPLACE_WITH_PRODUCTION_PROJECT_ID"
VITE_SUPABASE_URL="https://REPLACE_WITH_PRODUCTION_PROJECT_ID.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="REPLACE_WITH_PRODUCTION_ANON_KEY"
